{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@runtime-inspector/protocol": ["packages/protocol/src/index.ts"],
      "@runtime-inspector/transport-ws": ["packages/transport-ws/src/index.ts"],
      "@runtime-inspector/react-native": ["packages/runtime-react-native/src/index.ts"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  }
}
