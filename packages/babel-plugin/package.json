{
  "name": "@runtime-inspector/babel-plugin",
  "version": "0.1.0",
  "description": "Babel plugin: dev-only auto-binding of useSharedValue via an @inspect directive comment.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@babel/types": "^7.26.0",
    "@types/babel__core": "^7.20.5",
    "tsup": "^8.3.5",
    "vitest": "^4.1.9"
  }
}
